# =========================
# MedConnect Root .gitignore
# =========================

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Secrets / env
.env
.env.*
!.env.example
frontend/.env
backend/.env
*token.json*
*credentials.json*

# Python backend
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
venv/
.venv/

# Node / frontend
node_modules/
frontend/node_modules/
frontend/.expo/
frontend/.expo-shared/
frontend/.metro-cache/
frontend/.cache/
frontend/dist/
frontend/web-build/
frontend/expo-env.d.ts
*.tsbuildinfo

# React Native / Android build outputs
frontend/android/.gradle/
frontend/android/build/
frontend/android/app/build/

# Archive and binary artifacts
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
*.dmg
*.exe

# Misc
.ipynb_checkpoints/